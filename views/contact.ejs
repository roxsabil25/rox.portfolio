        <!-- Social Media -->
        <section class="mobile-section">
            <h2 class="text-2xl font-bold mb-6 text-center">
                <span class="gradient-text">SOCIAL BLAST</span>
            </h2>
            
            <div class="grid grid-cols-4 gap-3 mb-8">
                <a href="https://github.com/roxsabil25" class="social-button bg-[#333] aggressive-tap">
