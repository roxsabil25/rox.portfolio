    <!-- Success Modal -->
    <div id="successModal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4">
        <div class="aggressive-card max-w-md w-full form-success">
            <div class="text-center">
                <div class="w-20 h-20 bg-gradient-to-br from-green-600 to-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fas fa-check text-white text-3xl"></i>
                </div>
                <h3 class="text-2xl font-bold mb-4 gradient-text">MESSAGE LAUNCHED!</h3>
                <p class="text-gray-300 mb-6">Your project has been submitted. Expect an explosive response within 2 hours.</p>
                <button id="closeModal" class="aggressive-button aggressive-tap">
                    <i class="fas fa-fire mr-3"></i>
                    CONTINUE EXPLORING
                </button>
            </div>
        </div>
    </div>

    <!-- JavaScript -->
    <script>
        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const closeMenu = document.getElementById('closeMenu');
        const mobileMenu = document.getElementById('mobileMenu');
        
        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.add('open');
            document.body.style.overflow = 'hidden';
            createExplosion(menuToggle, 5);
        });
        
        closeMenu.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = 'auto';
            createExplosion(closeMenu, 3);
        });
        
        // Close menu when clicking outside
        mobileMenu.addEventListener('click', (e) => {
            if (e.target === mobileMenu) {
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Explosion Effect Function
        function createExplosion(element, count) {
            const rect = element.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            for (let i = 0; i < count; i++) {
                const explosion = document.createElement('div');
                explosion.className = 'explosion';
                explosion.style.background = getRandomColor();
                explosion.style.left = centerX + 'px';
                explosion.style.top = centerY + 'px';
                
                // Random properties
                const tx = (Math.random() - 0.5) * 100;
                const ty = (Math.random() - 0.5) * 100;
                const rot = Math.random() * 360;
                
                explosion.style.setProperty('--tx', tx + 'px');
                explosion.style.setProperty('--ty', ty + 'px');
                explosion.style.setProperty('--rot', rot + 'deg');
                
                document.body.appendChild(explosion);
                
                // Trigger animation
                setTimeout(() => {
                    explosion.classList.add('animate');
                }, 10);
                
                // Remove after animation
                setTimeout(() => {
                    explosion.remove();
                }, 600);
            }
        }
        
        function getRandomColor() {
            const colors = [
                'linear-gradient(45deg, #dc2626, #9333ea)',
                'linear-gradient(45deg, #3b82f6, #8b5cf6)',
                'linear-gradient(45deg, #10b981, #3b82f6)',
                'linear-gradient(45deg, #f59e0b, #dc2626)',
                'linear-gradient(45deg, #8b5cf6, #ec4899)'
            ];
            return colors[Math.floor(Math.random() * colors.length)];
        }
        
        // Budget Buttons
        const budgetButtons = document.querySelectorAll('.budget-btn');
        budgetButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                budgetButtons.forEach(b => b.style.background = 'rgba(255, 255, 255, 0.05)');
                this.style.background = 'linear-gradient(90deg, #dc2626, #9333ea)';
                createExplosion(this, 3);
            });
        });
        
        // Ripple Effect
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('aggressive-tap') || 
                e.target.closest('.aggressive-tap')) {
                const target = e.target.classList.contains('aggressive-tap') ? 
                    e.target : e.target.closest('.aggressive-tap');
                
                // Create ripple
                const ripple = document.createElement('span');
                const rect = target.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                const x = e.clientX - rect.left - size / 2;
                const y = e.clientY - rect.top - size / 2;
                
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = x + 'px';
                ripple.style.top = y + 'px';
                ripple.classList.add('ripple');
                
                target.style.position = 'relative';
                target.style.overflow = 'hidden';
                target.appendChild(ripple);
                
                // Remove ripple after animation
                setTimeout(() => {
                    ripple.remove();
                }, 600);
                
                // Add aggressive shake
                target.classList.add('animate-shake-aggressive');
                setTimeout(() => {
                    target.classList.remove('animate-shake-aggressive');
                }, 500);
            }
        });
        
        // Form Submission
        const aggressiveForm = document.getElementById('aggressiveForm');
        const successModal = document.getElementById('successModal');
        const closeModal = document.getElementById('closeModal');
        
        aggressiveForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Create big explosion
            createExplosion(this.querySelector('button[type="submit"]'), 10);
            
            // Show success modal after delay
            setTimeout(() => {
                successModal.classList.remove('hidden');
                successModal.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }, 800);
            
            // Reset form
            setTimeout(() => {
                aggressiveForm.reset();
                budgetButtons.forEach(b => b.style.background = 'rgba(255, 255, 255, 0.05)');
            }, 1000);
        });
        
        // Close success modal
        closeModal.addEventListener('click', function() {
            successModal.classList.add('hidden');
            successModal.classList.remove('flex');
            document.body.style.overflow = 'auto';
            createExplosion(this, 5);
        });
        
        // Social media button animations
        const socialButtons = document.querySelectorAll('.social-button');
        socialButtons.forEach(btn => {
            btn.addEventListener('mouseenter', () => {
                btn.classList.add('animate-float-aggressive');
            });
            
            btn.addEventListener('mouseleave', () => {
                btn.classList.remove('animate-float-aggressive');
            });
        });
        
        // Contact method animations
        const contactMethods = document.querySelectorAll('.contact-method');
        contactMethods.forEach(method => {
            method.addEventListener('click', function() {
                createExplosion(this, 4);
                
                // Add temporary glow
                this.classList.add('neon-glow');
                setTimeout(() => {
                    this.classList.remove('neon-glow');
                }, 1000);
            });
        });
        
        // Initialize animations
        document.addEventListener('DOMContentLoaded', function() {
            // Animate cards sequentially
            const explodeCards = document.querySelectorAll('.animate-explode');
            explodeCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
            });
            
            // Add floating particles
            createFloatingParticles();
            
            // Auto shake header occasionally
            setInterval(() => {
                const header = document.querySelector('.mobile-header');
                header.classList.add('animate-shake-aggressive');
                setTimeout(() => {
                    header.classList.remove('animate-shake-aggressive');
                }, 500);
            }, 10000);
        });
        
        // Create floating particles
        function createFloatingParticles() {
            const container = document.querySelector('main');
            const particles = 8;
            
            for (let i = 0; i < particles; i++) {
                const particle = document.createElement('div');
                particle.className = 'absolute w-2 h-2 rounded-full hidden md:block';
                particle.style.background = getRandomColor();
                particle.style.opacity = '0.3';
                
                // Random positioning
                const left = Math.random() * 100;
                const top = Math.random() * 100;
                const duration = 3 + Math.random() * 4;
                const delay = Math.random() * 5;
                
                particle.style.left = `${left}%`;
                particle.style.top = `${top}%`;
                particle.style.animation = `float-aggressive ${duration}s ease-in-out infinite`;
                particle.style.animationDelay = `${delay}s`;
                
                container.appendChild(particle);
            }
        }
        
        // Emergency mode toggle
        const emergencyToggle = document.querySelector('.mobile-header button:first-child');
        let emergencyMode = false;
        
        emergencyToggle.addEventListener('click', function() {
            emergencyMode = !emergencyMode;
            
            if (emergencyMode) {
                document.body.style.background = 'linear-gradient(45deg, #000000, #1a0000)';
                this.innerHTML = '<i class="fas fa-fire"></i>';
                this.style.background = 'linear-gradient(90deg, #dc2626, #ff0000)';
                this.classList.add('animate-aggressive-pulse');
                
                // Add emergency animation to all buttons
                document.querySelectorAll('.aggressive-button').forEach(btn => {
                    btn.style.background = 'linear-gradient(90deg, #ff0000, #ff6b6b)';
                    btn.classList.add('animate-aggressive-pulse');
                });
                
                // Show emergency notification
                showEmergencyNotification();
            } else {
                document.body.style.background = '#000000';
                this.innerHTML = '<i class="fas fa-bolt"></i>';
                this.style.background = '';
                this.classList.remove('animate-aggressive-pulse');
                
                // Reset buttons
                document.querySelectorAll('.aggressive-button').forEach(btn => {
                    btn.style.background = '';
                    btn.classList.remove('animate-aggressive-pulse');
                });
            }
            
            createExplosion(this, 6);
        });
        
        // Show emergency notification
        function showEmergencyNotification() {
            const notification = document.createElement('div');
            notification.className = 'fixed top-20 left-4 right-4 bg-gradient-to-r from-red-600 to-red-800 p-4 rounded-xl z-50 animate-explode';
            notification.innerHTML = `
                <div class="flex items-center gap-3">
                    <i class="fas fa-exclamation-triangle text-2xl"></i>
                    <div>
                        <h4 class="font-bold">EMERGENCY MODE ACTIVATED</h4>
                        <p class="text-sm opacity-90">Priority response enabled. All systems at maximum.</p>
                    </div>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
        
        // Handle orientation change
        window.addEventListener('orientationchange', function() {
            // Refresh animations
            setTimeout(() => {
                document.querySelectorAll('.animate-explode').forEach(el => {
                    el.style.animation = 'none';
                    setTimeout(() => {
                        el.style.animation = '';
                    }, 10);
                });
            }, 300);
        });
    </script>
</body>
