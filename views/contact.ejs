            </div>
            
            <!-- Call Schedule -->
            <div class="aggressive-card animate-explode" style="animation-delay: 0.5s">
                <h3 class="text-lg font-bold mb-4 text-center">SCHEDULE A CALL</h3>
                <div class="text-center">
                    <p class="text-gray-300 mb-4">Pick a time slot for a 15-minute explosive discussion</p>
                    <button class="aggressive-button aggressive-tap w-full max-w-xs mx-auto">
