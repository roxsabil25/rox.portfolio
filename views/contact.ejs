                <div class="text-center">
                    <div class="w-16 h-16 bg-gradient-to-br from-red-600 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 animate-aggressive-pulse">
                        <i class="fas fa-clock text-white text-2xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-2 gradient-text">RESPONSE TIME GUARANTEE</h3>
                    <p class="text-gray-300 mb-4">I guarantee a response within 2 hours for all inquiries. 24/7 emergency support available.</p>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div class="text-center">
                            <div class="text-3xl font-bold text-red-500">2h</div>
