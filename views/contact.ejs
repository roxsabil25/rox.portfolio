                            <h3 class="text-lg font-bold mb-2">LOCATION</h3>
                            <p class="text-gray-300">Mirpur-12, Dhaka, Bangladesh</p>
                            <p class="text-gray-400 text-sm mt-1">Available worldwide • Timezone: BST</p>
                        </div>
