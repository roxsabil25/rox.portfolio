    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #000000;
            color: #ffffff;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Mobile Optimizations */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            /* Improve touch targets */
            button, a, .touch-target {
                min-height: 44px;
                min-width: 44px;
            }
            
            /* Better scrolling */
            .scroll-smooth {
                scroll-behavior: smooth;
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #dc2626, #9333ea);
            border-radius: 3px;
        }
        
        /* Aggressive Mobile Animations */
        @keyframes aggressive-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; box-shadow: 0 0 30px rgba(220, 38, 38, 0.6); }
        }
        
        @keyframes shake-aggressive {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-8px); }
            20%, 40%, 60%, 80% { transform: translateX(8px); }
        }
        
        @keyframes explode {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        
        @keyframes float-aggressive {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            33% { transform: translateY(-15px) rotate(5deg); }
            66% { transform: translateY(10px) rotate(-5deg); }
        }
        
        @keyframes neon-flicker {
            0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
                opacity: 1;
                text-shadow: 0 0 10px #dc2626, 0 0 20px #dc2626, 0 0 30px #dc2626;
            }
            20%, 24%, 55% {
                opacity: 0.7;
                text-shadow: none;
            }
        }
        
        .animate-aggressive-pulse {
            animation: aggressive-pulse 1.5s infinite;
        }
        
        .animate-shake-aggressive {
            animation: shake-aggressive 0.5s;
        }
        
        .animate-explode {
            animation: explode 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        .animate-float-aggressive {
            animation: float-aggressive 5s ease-in-out infinite;
        }
        
        .animate-neon-flicker {
            animation: neon-flicker 1.5s infinite;
        }
        
        /* Touch Feedback */
        .aggressive-tap:active {
            transform: scale(0.9) !important;
            transition: transform 0.1s !important;
        }
        
        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.5rem 0;
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.3s;
        }
        
        .mobile-nav-item.active {
            background: rgba(220, 38, 38, 0.2);
            color: #dc2626;
        }
        
        .mobile-nav-item:active {
            background: rgba(220, 38, 38, 0.3);
            transform: scale(0.9);
        }
        
        /* Mobile Header */
        .mobile-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.75rem 1rem;
        }
        
        /* Mobile Menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            overflow-y: auto;
        }
        
        .mobile-menu.open {
            transform: translateX(0);
        }
        
        /* Aggressive Cards */
        .aggressive-card {
            background: linear-gradient(145deg, rgba(20, 20, 20, 0.9), rgba(0, 0, 0, 0.9));
            border: 2px solid;
            border-image: linear-gradient(45deg, #dc2626, #9333ea, #dc2626) 1;
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .aggressive-card::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #dc2626, #9333ea, #dc2626);
            border-radius: 22px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .aggressive-card:hover::before,
        .aggressive-card:active::before {
            opacity: 1;
        }
        
        .aggressive-card:active {
            transform: scale(0.97) !important;
        }
        
        /* Aggressive Input */
        .aggressive-input {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1rem;
            color: white;
            font-size: 1rem;
            transition: all 0.3s;
            width: 100%;
        }
        
        .aggressive-input:focus {
            outline: none;
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.3);
            background: rgba(255, 255, 255, 0.1);
        }
        
        /* Aggressive Button */
        .aggressive-button {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            border-radius: 15px;
            font-weight: 700;
            border: none;
            width: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .aggressive-button::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(rgba(255, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: transform 0.5s;
        }
        
        .aggressive-button:hover::after,
        .aggressive-button:active::after {
            transform: rotate(45deg) translate(50%, 50%);
        }
        
        .aggressive-button:active {
            transform: scale(0.95);
        }
        
        /* Explosion Effect */
        .explosion {
            position: absolute;
            width: 20px;
            height: 20px;
            pointer-events: none;
            opacity: 0;
        }
        
        .explosion.animate {
            animation: explode-particle 0.6s forwards;
        }
        
        @keyframes explode-particle {
            0% { transform: scale(0) rotate(0deg); opacity: 1; }
            100% { transform: scale(1) translate(var(--tx), var(--ty)) rotate(var(--rot)); opacity: 0; }
        }
        
        /* Neon Glow */
        .neon-glow {
            text-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
        }
        
        /* Ripple Effect */
        .ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: scale(0);
            animation: ripple-animation 0.6s linear;
            pointer-events: none;
        }
        
        @keyframes ripple-animation {
            to {
                transform: scale(4);
                opacity: 0;
            }
        }
        
        /* Pulsing Border */
        .pulsing-border {
            position: relative;
            border: 2px solid transparent;
            border-radius: 15px;
        }
        
        .pulsing-border::before {
            content: '';
            position: absolute;
            top: -4px;
            left: -4px;
            right: -4px;
            bottom: -4px;
            border-radius: 17px;
            background: linear-gradient(45deg, #dc2626, #9333ea, #dc2626);
            z-index: -1;
            opacity: 0.5;
            animation: pulse-border 2s infinite;
        }
        
        @keyframes pulse-border {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }
        
        /* Contact Method Card */
        .contact-method {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid transparent;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .contact-method::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            transform: scaleX(0);
            transition: transform 0.3s;
        }
        
        .contact-method:hover::before,
        .contact-method:active::before {
            transform: scaleX(1);
        }
        
        .contact-method:active {
            transform: translateY(-5px);
        }
        
        /* Social Media Buttons */
        .social-button {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .social-button::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, rgba(255,255,255,0.3) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .social-button:hover::after,
        .social-button:active::after {
            opacity: 1;
        }
        
        .social-button:active {
            transform: scale(0.9);
        }
        
        /* Status Indicator */
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            position: relative;
        }
        
        .status-indicator.online {
            background: #10b981;
            box-shadow: 0 0 10px #10b981;
        }
        
        .status-indicator.offline {
            background: #ef4444;
            box-shadow: 0 0 10px #ef4444;
        }
        
        .status-indicator::after {
            content: '';
            position: absolute;
            top: -4px;
            left: -4px;
            right: -4px;
            bottom: -4px;
            border-radius: 50%;
            border: 2px solid currentColor;
            opacity: 0.5;
            animation: status-pulse 2s infinite;
        }
        
        @keyframes status-pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 0.2; }
        }
        
        /* Form Success Animation */
        @keyframes form-success {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        
        .form-success {
            animation: form-success 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        /* Mobile Section */
        .mobile-section {
            padding: 2rem 1rem;
        }
        
        /* Gradient Text */
        .gradient-text {
            background: linear-gradient(90deg, #dc2626, #9333ea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
    </style>
</head>
