    <!-- JavaScript -->
    <script>
        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const closeMenu = document.getElementById('closeMenu');
        const mobileMenu = document.getElementById('mobileMenu');
        
        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.add('open');
            document.body.style.overflow = 'hidden';
            animateButton(menuToggle);
        });
        
        closeMenu.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = 'auto';
            animateButton(closeMenu);
        });
        
        // Close menu when clicking outside
        mobileMenu.addEventListener('click', (e) => {
            if (e.target === mobileMenu) {
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Section jump from menu
        document.querySelectorAll('.section-jump').forEach(button => {
            button.addEventListener('click', function() {
                const sectionId = this.getAttribute('data-section');
                const sectionElement = document.getElementById(sectionId);
                
                if (sectionElement) {
                    window.scrollTo({
                        top: sectionElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
                
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
                animateButton(this);
                
                // Add shake animation to section
                if (sectionElement) {
                    sectionElement.classList.add('animate-cv-shake');
                    setTimeout(() => {
                        sectionElement.classList.remove('animate-cv-shake');
                    }, 500);
                }
            });
        });
        
        // Section toggle functionality
        document.querySelectorAll('.section-toggle').forEach(toggle => {
            toggle.addEventListener('click', function() {
                const content = this.nextElementSibling;
                const icon = this.querySelector('.fa-chevron-down');
                
                if (content.classList.contains('expanded')) {
                    content.classList.remove('expanded');
                    icon.style.transform = 'rotate(0deg)';
                } else {
                    content.classList.add('expanded');
                    icon.style.transform = 'rotate(180deg)';
                }
                
                animateButton(this);
            });
        });
        
        // Download CV button
        document.getElementById('downloadCV').addEventListener('click', function() {
            // Show loading state
            const originalHTML = this.innerHTML;
            this.innerHTML = '<i class="fas fa-spinner fa-spin mr-3"></i> GENERATING PDF...';
            this.disabled = true;
            
            // Simulate PDF generation
            setTimeout(() => {
                alert('CV PDF generated successfully! Download starting...');
                this.innerHTML = originalHTML;
                this.disabled = false;
                
                // Trigger shake animation on all sections
                document.querySelectorAll('.cv-section').forEach(section => {
                    section.classList.add('animate-cv-shake');
                    setTimeout(() => {
                        section.classList.remove('animate-cv-shake');
                    }, 500);
                });
                
                // Animate skill bars
                document.querySelectorAll('.skill-bar-fill').forEach(bar => {
                    bar.style.animation = 'none';
                    setTimeout(() => {
                        bar.style.animation = '';
                    }, 100);
                });
            }, 1500);
            
            animateButton(this);
        });
        
        // Menu download button
        document.getElementById('menuDownload').addEventListener('click', function() {
            document.getElementById('downloadCV').click();
            mobileMenu.classList.remove('open');
            document.body.style.overflow = 'auto';
            animateButton(this);
        });
        
        // Share CV button
        document.getElementById('shareCV').addEventListener('click', function() {
            if (navigator.share) {
                navigator.share({
                    title: 'RoX Sabil - CV/Resume',
                    text: 'Check out my professional CV/Resume',
                    url: window.location.href
                });
            } else {
                alert('CV link copied to clipboard!');
                navigator.clipboard.writeText(window.location.href);
            }
            animateButton(this);
        });
        
        // Print CV button
        document.getElementById('printCV').addEventListener('click', function() {
            window.print();
            animateButton(this);
        });
        
        // Animate skill bars on scroll
        const skillBars = document.querySelectorAll('.skill-bar-fill');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const skillBar = entry.target;
                    skillBar.style.width = '0%';
                    
                    setTimeout(() => {
                        skillBar.style.width = skillBar.style.getPropertyValue('--skill-width');
                    }, 300);
                    
                    observer.unobserve(skillBar);
                }
            });
        }, { threshold: 0.5 });
        
        skillBars.forEach(bar => {
            observer.observe(bar);
        });
        
        // Button animation
        function animateButton(button) {
            button.style.transform = 'scale(0.95)';
            setTimeout(() => {
                button.style.transform = '';
            }, 100);
        }
        
        // Initialize on load
        document.addEventListener('DOMContentLoaded', function() {
            // Animate skill bars on page load for visible ones
            setTimeout(() => {
                document.querySelectorAll('.skill-bar-fill').forEach(bar => {
                    bar.classList.add('animate-skill-bar');
                });
            }, 500);
            
            // Animate all badges
            document.querySelectorAll('.badge-highlight').forEach((badge, index) => {
                badge.style.animationDelay = `${index * 0.5}s`;
            });
            
            // Add click animation to contact info
            document.querySelectorAll('.contact-info').forEach(item => {
                item.addEventListener('click', function() {
                    this.classList.add('animate-cv-shake');
                    setTimeout(() => {
                        this.classList.remove('animate-cv-shake');
                    }, 500);
                });
            });
            
            // Auto-expand first section if collapsed
            const firstSection = document.querySelector('.section-content');
            if (firstSection && !firstSection.classList.contains('expanded')) {
                firstSection.classList.add('expanded');
                const icon = firstSection.previousElementSibling.querySelector('.fa-chevron-down');
                if (icon) {
                    icon.style.transform = 'rotate(180deg)';
                }
            }
            
            // Add floating particles animation
            createFloatingParticles();
        });
        
        // Create floating particles
        function createFloatingParticles() {
            const container = document.querySelector('main');
            const particles = 6;
            
            for (let i = 0; i < particles; i++) {
                const particle = document.createElement('div');
                particle.className = 'absolute w-1 h-1 rounded-full hidden md:block';
                
                // Random gradient color
                const gradients = [
                    'linear-gradient(45deg, #dc2626, #9333ea)',
                    'linear-gradient(45deg, #3b82f6, #8b5cf6)',
                    'linear-gradient(45deg, #10b981, #3b82f6)',
                    'linear-gradient(45deg, #f59e0b, #dc2626)'
                ];
                
                particle.style.background = gradients[Math.floor(Math.random() * gradients.length)];
                particle.style.opacity = '0.3';
                
                // Random positioning
                const left = Math.random() * 100;
                const top = Math.random() * 100;
                const duration = 4 + Math.random() * 4;
                const delay = Math.random() * 5;
                
                particle.style.left = `${left}%`;
                particle.style.top = `${top}%`;
                particle.style.animation = `float 6s ease-in-out infinite`;
                particle.style.animationDelay = `${delay}s`;
                
                // Add float animation if not exists
                if (!document.querySelector('style[data-float-animation]')) {
                    const style = document.createElement('style');
                    style.setAttribute('data-float-animation', 'true');
                    style.textContent = `
                        @keyframes float {
                            0%, 100% { transform: translateY(0) rotate(0deg); }
                            33% { transform: translateY(-10px) rotate(5deg); }
                            66% { transform: translateY(5px) rotate(-5deg); }
                        }
                    `;
                    document.head.appendChild(style);
                }
                
                container.appendChild(particle);
            }
        }
        
        // Handle orientation change
        window.addEventListener('orientationchange', function() {
            setTimeout(() => {
                // Refresh animations
                document.querySelectorAll('.animate-section-glow').forEach(el => {
                    el.style.animation = 'none';
                    setTimeout(() => {
                        el.style.animation = '';
                    }, 10);
                });
            }, 300);
        });
        
        // Touch feedback for all interactive elements
        document.addEventListener('touchstart', function() {}, { passive: true });
    </script>
