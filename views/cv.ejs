<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link  rel="icon" type="image/png" href="/img/WhatsApp Image 2024-11-13 at 10.57.50_e7f206ab.jpg">
    <title>CV - RoX Sabil </title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #000000;
            color: #ffffff;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Mobile Optimizations */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            /* Improve touch targets */
            button, a, .touch-target {
                min-height: 44px;
                min-width: 44px;
            }
            
            /* Better scrolling */
            .scroll-smooth {
                scroll-behavior: smooth;
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #dc2626, #9333ea);
            border-radius: 3px;
        }
        
        /* Aggressive Animations */
        @keyframes cv-shake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
            20%, 40%, 60%, 80% { transform: translateX(5px); }
        }
        
        @keyframes badge-spin {
            0% { transform: rotate(0deg) scale(1); }
            50% { transform: rotate(180deg) scale(1.1); }
            100% { transform: rotate(360deg) scale(1); }
        }
        
        @keyframes section-glow {
            0%, 100% { box-shadow: 0 0 0 rgba(220, 38, 38, 0); }
            50% { box-shadow: 0 0 30px rgba(220, 38, 38, 0.3); }
        }
        
        @keyframes skill-bar-fill {
            0% { width: 0%; }
            100% { width: var(--skill-width); }
        }
        
        @keyframes timeline-pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }
        
        .animate-cv-shake {
            animation: cv-shake 0.5s;
        }
        
        .animate-badge-spin {
            animation: badge-spin 2s linear infinite;
        }
        
        .animate-section-glow {
            animation: section-glow 3s infinite;
        }
        
        .animate-skill-bar {
            animation: skill-bar-fill 1.5s ease-out forwards;
        }
        
        .animate-timeline-pulse {
            animation: timeline-pulse 2s infinite;
        }
        
        /* Touch Feedback */
        .aggressive-tap:active {
            transform: scale(0.9) !important;
            transition: transform 0.1s !important;
        }
        
        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.5rem 0;
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.3s;
        }
        
        .mobile-nav-item.active {
            background: rgba(220, 38, 38, 0.2);
            color: #dc2626;
        }
        
        .mobile-nav-item:active {
            background: rgba(220, 38, 38, 0.3);
            transform: scale(0.9);
        }
        
        /* Mobile Header */
        .mobile-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.75rem 1rem;
        }
        
        /* Mobile Menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            overflow-y: auto;
        }
        
        .mobile-menu.open {
            transform: translateX(0);
        }
        
        /* CV Section Cards */
        .cv-section {
            background: linear-gradient(145deg, rgba(20, 20, 20, 0.9), rgba(0, 0, 0, 0.9));
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 2px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .cv-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            transform: scaleX(0);
            transition: transform 0.3s;
        }
        
        .cv-section:hover::before,
        .cv-section:active::before {
            transform: scaleX(1);
        }
        
        .cv-section:active {
            transform: scale(0.99);
            border-color: rgba(220, 38, 38, 0.3);
        }
        
        /* Skill Bar */
        .skill-bar {
            height: 10px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 5px;
            overflow: hidden;
            margin-top: 0.5rem;
        }
        
        .skill-bar-fill {
            height: 100%;
            border-radius: 5px;
            position: relative;
            overflow: hidden;
        }
        
        .skill-bar-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, 
                rgba(255, 255, 255, 0.2) 0%, 
                rgba(255, 255, 255, 0.4) 50%, 
                rgba(255, 255, 255, 0.2) 100%);
            animation: skill-shimmer 2s infinite;
        }
        
        @keyframes skill-shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        /* Timeline */
        .timeline {
            position: relative;
            padding-left: 2rem;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 0.75rem;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #dc2626, #9333ea);
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 2rem;
        }
        
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.2rem;
            top: 0.5rem;
            width: 1rem;
            height: 1rem;
            background: #dc2626;
            border-radius: 50%;
            border: 3px solid #000;
        }
        
        /* Badge */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50px;
            margin: 0.25rem;
            font-size: 0.8rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .badge-highlight {
            background: linear-gradient(90deg, rgba(220, 38, 38, 0.2), rgba(147, 51, 234, 0.2));
            border-color: #dc2626;
        }
        
        /* Download Button */
        .download-button {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            border-radius: 15px;
            font-weight: 700;
            border: none;
            width: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .download-button::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(rgba(255, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: transform 0.5s;
        }
        
        .download-button:hover::after,
        .download-button:active::after {
            transform: rotate(45deg) translate(50%, 50%);
        }
        
        .download-button:active {
            transform: scale(0.95);
        }
        
        /* CV Stats */
        .cv-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin: 1.5rem 0;
        }
        
        .stat-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s;
        }
        
        .stat-item:active {
            transform: scale(0.98);
            border-color: rgba(220, 38, 38, 0.3);
        }
        
        /* Contact Info */
        .contact-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            margin-bottom: 1rem;
        }
        
        /* Language Meter */
        .language-meter {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .language-level {
            flex: 1;
            height: 6px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            overflow: hidden;
        }
        
        .language-level-fill {
            height: 100%;
            border-radius: 3px;
        }
        
        /* Print Styles */
        @media print {
            .mobile-header,
            .mobile-nav,
            .mobile-menu,
            .download-button,
            .no-print {
                display: none !important;
            }
            
            body {
                background: white;
                color: black;
            }
            
            .cv-section {
                border: 1px solid #ddd;
                background: white;
                break-inside: avoid;
            }
        }
        
        /* Mobile Section */
        .mobile-section {
            padding: 2rem 1rem;
        }
        
        /* Gradient Text */
        .gradient-text {
            background: linear-gradient(90deg, #dc2626, #9333ea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        /* Section Toggle */
        .section-toggle {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }
        
        .section-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease;
        }
        
        .section-content.expanded {
            max-height: 2000px;
        }
        
        /* QR Code for CV */
        .qr-container {
            width: 150px;
            height: 150px;
            background: white;
            border-radius: 10px;
            padding: 10px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: center;
            color: black;
            font-weight: bold;
        }
    </style>
</head>
