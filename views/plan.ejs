    <!-- JavaScript -->
    <script>
        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const closeMenu = document.getElementById('closeMenu');
        const mobileMenu = document.getElementById('mobileMenu');
        
        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.add('open');
            document.body.style.overflow = 'hidden';
            animateButton(menuToggle);
        });
        
        closeMenu.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = 'auto';
            animateButton(closeMenu);
        });
        
        // Close menu when clicking outside
        mobileMenu.addEventListener('click', (e) => {
            if (e.target === mobileMenu) {
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Quick jump buttons
        document.querySelectorAll('[data-scroll]').forEach(button => {
            button.addEventListener('click', function() {
                const targetId = this.getAttribute('data-scroll');
                const targetElement = document.getElementById(targetId);
                
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
                
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
                animateButton(this);
            });
        });
        
        // Plan selection
        const planCards = document.querySelectorAll('.plan-card');
        let selectedPlan = 'pro'; // Default selected
        
        planCards.forEach(card => {
            card.addEventListener('click', function() {
                const plan = this.getAttribute('data-plan');
                selectedPlan = plan;
                
                // Remove all selections
                planCards.forEach(c => {
                    c.style.border = '2px solid rgba(255, 255, 255, 0.1)';
                    c.querySelector('.plan-button').style.background = 'rgba(255, 255, 255, 0.1)';
                });
                
                // Highlight selected
                this.style.border = '2px solid #dc2626';
                this.querySelector('.plan-button').style.background = 'linear-gradient(90deg, #dc2626, #9333ea)';
                
                // Shake animation for price
                const priceElement = this.querySelector('.gradient-text');
                priceElement.classList.add('animate-price-shake');
                setTimeout(() => {
                    priceElement.classList.remove('animate-price-shake');
                }, 500);
                
                animateButton(this);
            });
        });
        
        // Custom plan button
        document.getElementById('customPlanBtn').addEventListener('click', function() {
            showRocketAnimation();
            setTimeout(() => {
                document.getElementById('successModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
                document.getElementById('orderId').textContent = 'CUST-' + Math.floor(Math.random() * 1000);
            }, 2000);
            animateButton(this);
        });
        
        // Plan buttons
        document.querySelectorAll('.plan-button').forEach(button => {
            if (!button.id) { // Exclude special buttons
                button.addEventListener('click', function(e) {
                    e.stopPropagation();
                    showRocketAnimation();
                    setTimeout(() => {
                        document.getElementById('successModal').style.display = 'flex';
                        document.body.style.overflow = 'hidden';
                        document.getElementById('orderId').textContent = 'RX-' + Math.floor(Math.random() * 1000);
                    }, 2000);
                    animateButton(this);
                });
            }
        });
        
        // Final CTA button
        document.getElementById('finalCta').addEventListener('click', function() {
            showRocketAnimation();
            setTimeout(() => {
                document.getElementById('successModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
                document.getElementById('orderId').textContent = 'FINAL-' + Math.floor(Math.random() * 1000);
            }, 2000);
            animateButton(this);
        });
        
        // Schedule call button
        document.getElementById('scheduleCall').addEventListener('click', function() {
            alert('Redirecting to calendar scheduling...');
            animateButton(this);
        });
        
        // Close success modal
        document.getElementById('closeSuccess').addEventListener('click', function() {
            document.getElementById('successModal').style.display = 'none';
            document.body.style.overflow = 'auto';
            animateButton(this);
        });
        
        // Payment methods
        const paymentMethods = document.querySelectorAll('.payment-method');
        paymentMethods.forEach(method => {
            method.addEventListener('click', function() {
                paymentMethods.forEach(m => m.classList.remove('active'));
                this.classList.add('active');
                animateButton(this);
            });
        });
        
        // FAQ toggle
        const faqItems = document.querySelectorAll('.faq-item');
        faqItems.forEach(item => {
            item.addEventListener('click', function() {
                const isActive = this.classList.contains('active');
                
                // Close all other items
                faqItems.forEach(i => i.classList.remove('active'));
                
                // Toggle current item
                if (!isActive) {
                    this.classList.add('active');
                }
                
                animateButton(this);
            });
        });
        
        // Timer toggle
        let timerVisible = true;
        document.getElementById('timerToggle').addEventListener('click', function() {
            const timer = document.getElementById('countdownTimer');
            if (timerVisible) {
                timer.style.display = 'none';
                this.innerHTML = '<i class="fas fa-clock-slash"></i>';
            } else {
                timer.style.display = 'flex';
                this.innerHTML = '<i class="fas fa-clock"></i>';
            }
            timerVisible = !timerVisible;
            animateButton(this);
        });
        
        // Countdown timer
        function updateCountdown() {
            const hoursElement = document.getElementById('countdown-hours');
            const minutesElement = document.getElementById('countdown-minutes');
            const secondsElement = document.getElementById('countdown-seconds');
            
            let hours = parseInt(hoursElement.textContent);
            let minutes = parseInt(minutesElement.textContent);
            let seconds = parseInt(secondsElement.textContent);
            
            seconds--;
            
            if (seconds < 0) {
                seconds = 59;
                minutes--;
                
                if (minutes < 0) {
                    minutes = 59;
                    hours--;
                    
                    if (hours < 0) {
                        hours = 23;
                        minutes = 59;
                        seconds = 59;
                    }
                }
            }
            
            hoursElement.textContent = hours.toString().padStart(2, '0');
            minutesElement.textContent = minutes.toString().padStart(2, '0');
            secondsElement.textContent = seconds.toString().padStart(2, '0');
            
            // Flash animation on 59 seconds
            if (seconds === 59) {
                secondsElement.classList.add('animate-countdown-flash');
                setTimeout(() => {
                    secondsElement.classList.remove('animate-countdown-flash');
                }, 1000);
            }
        }
        
        // Animate counters
        function animateCounter(elementId, target, duration = 2000) {
            const element = document.getElementById(elementId);
            let start = 0;
            const increment = target / (duration / 16); // 60fps
            
            const timer = setInterval(() => {
                start += increment;
                if (start >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(start);
                }
            }, 16);
        }
        
        // Show rocket animation
        function showRocketAnimation() {
            const rocketContainer = document.getElementById('rocketContainer');
            const rocket = rocketContainer.querySelector('.rocket');
            
            rocketContainer.style.display = 'block';
            rocket.classList.add('animate-rocket-launch');
            
            setTimeout(() => {
                rocketContainer.style.display = 'none';
                rocket.classList.remove('animate-rocket-launch');
            }, 2000);
        }
        
        // Button animation
        function animateButton(button) {
            button.style.transform = 'scale(0.95)';
            setTimeout(() => {
                button.style.transform = '';
            }, 100);
        }
        
        // Initialize on load
        document.addEventListener('DOMContentLoaded', function() {
            // Start countdown timer
            setInterval(updateCountdown, 1000);
            
            // Animate counters
           setTimeout(() => animateCounter('clients-counter', 32 , 1500), 50);
            setTimeout(() => animateCounter('projects-counter', 47, 1500), 1000);
            setTimeout(() => animateCounter('success-counter', 98, 1500), 1500);
            
            // Auto-select Pro plan
            const proPlan = document.querySelector('.plan-card[data-plan="pro"]');
            if (proPlan) {
                proPlan.style.border = '2px solid #dc2626';
                proPlan.querySelector('.plan-button').style.background = 'linear-gradient(90deg, #dc2626, #9333ea)';
            }
            
            // Animate progress bars
            const progressBars = document.querySelectorAll('.plan-progress-fill');
            progressBars.forEach(bar => {
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {
                    bar.style.width = width;
                }, 1000);
            });
            
            // Add touch feedback to all aggressive-tap elements
            document.addEventListener('touchstart', function() {}, { passive: true });
            
            // Auto-open first FAQ
            if (faqItems.length > 0) {
                setTimeout(() => {
                    faqItems[0].classList.add('active');
                }, 1000);
            }
            
            // Random order ID
            document.getElementById('orderId').textContent = 'RX-' + Math.floor(Math.random() * 1000);
        });
        
        // Handle orientation change
        window.addEventListener('orientationchange', function() {
            setTimeout(() => {
                // Refresh animations
                document.querySelectorAll('.animate-feature-pulse').forEach(el => {
                    el.style.animation = 'none';
                    setTimeout(() => {
                        el.style.animation = '';
                    }, 10);
                });
            }, 300);
        });
    </script>
