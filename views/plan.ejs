<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link  rel="icon" type="image/png" href="/img/WhatsApp Image 2024-11-13 at 10.57.50_e7f206ab.jpg">
    <title>Plan - RoX Sabil</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #000000;
            color: #ffffff;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Mobile Optimizations */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            /* Improve touch targets */
            button, a, .touch-target {
                min-height: 44px;
                min-width: 44px;
            }
            
            /* Better scrolling */
            .scroll-smooth {
                scroll-behavior: smooth;
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #dc2626, #9333ea);
            border-radius: 3px;
        }
        
        /* Aggressive Animations */
        @keyframes rocket-launch {
            0% { transform: translateY(0) rotate(0deg); }
            30% { transform: translateY(-20px) rotate(-5deg); }
            60% { transform: translateY(-40px) rotate(5deg); }
            100% { transform: translateY(-100vh) rotate(0deg); }
        }
        
        @keyframes price-shake {
            0%, 100% { transform: scale(1); }
            25% { transform: scale(1.05) rotate(2deg); }
            75% { transform: scale(1.05) rotate(-2deg); }
        }
        
        @keyframes gradient-blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        
        @keyframes feature-pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0 rgba(220, 38, 38, 0); }
            50% { transform: scale(1.05); box-shadow: 0 0 20px rgba(220, 38, 38, 0.5); }
        }
        
        @keyframes countdown-flash {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.1); }
        }
        
        .animate-rocket-launch {
            animation: rocket-launch 2s forwards;
        }
        
        .animate-price-shake {
            animation: price-shake 0.5s;
        }
        
        .animate-gradient-blink {
            animation: gradient-blink 2s infinite;
        }
        
        .animate-feature-pulse {
            animation: feature-pulse 2s infinite;
        }
        
        .animate-countdown-flash {
            animation: countdown-flash 1s infinite;
        }
        
        /* Touch Feedback */
        .aggressive-tap:active {
            transform: scale(0.9) !important;
            transition: transform 0.1s !important;
        }
        
        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.5rem 0;
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.3s;
        }
        
        .mobile-nav-item.active {
            background: rgba(220, 38, 38, 0.2);
            color: #dc2626;
        }
        
        .mobile-nav-item:active {
            background: rgba(220, 38, 38, 0.3);
            transform: scale(0.9);
        }
        
        /* Mobile Header */
        .mobile-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.75rem 1rem;
        }
        
        /* Mobile Menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            overflow-y: auto;
        }
        
        .mobile-menu.open {
            transform: translateX(0);
        }
        
        /* Plan Cards */
        .plan-card {
            background: linear-gradient(145deg, rgba(20, 20, 20, 0.9), rgba(0, 0, 0, 0.9));
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
            border: 2px solid rgba(255, 255, 255, 0.1);
        }
        
        .plan-card.popular {
            border: 2px solid;
            border-image: linear-gradient(45deg, #dc2626, #9333ea) 1;
            transform: scale(1.05);
            z-index: 2;
        }
        
        .plan-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, rgba(220, 38, 38, 0.1), rgba(147, 51, 234, 0.1));
            opacity: 0;
            transition: opacity 0.3s;
            z-index: -1;
        }
        
        .plan-card:hover::before,
        .plan-card:active::before {
            opacity: 1;
        }
        
        .plan-card:active {
            transform: scale(0.97);
        }
        
        .plan-card.popular:active {
            transform: scale(1.02);
        }
        
        /* Ribbon for Popular Plan */
        .popular-ribbon {
            position: absolute;
            top: 20px;
            right: -30px;
            background: linear-gradient(45deg, #dc2626, #9333ea);
            color: white;
            padding: 0.5rem 3rem;
            transform: rotate(45deg);
            font-weight: bold;
            font-size: 0.8rem;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
        }
        
        /* Plan Feature */
        .plan-feature {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }
        
        .feature-check {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: rgba(34, 197, 94, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .feature-cross {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: rgba(239, 68, 68, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        /* Plan Button */
        .plan-button {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            border-radius: 12px;
            font-weight: 700;
            border: none;
            width: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .plan-button::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(rgba(255, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: transform 0.5s;
        }
        
        .plan-button:hover::after,
        .plan-button:active::after {
            transform: rotate(45deg) translate(50%, 50%);
        }
        
        /* Comparison Table */
        .comparison-row {
            display: flex;
            justify-content: space-between;
            padding: 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .comparison-row.header {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px 10px 0 0;
        }
        
        /* Countdown Timer */
        .countdown-timer {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
        }
        
        .countdown-unit {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 0.5rem;
            min-width: 60px;
            text-align: center;
        }
        
        /* Progress Bar */
        .plan-progress {
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            margin: 1rem 0;
        }
        
        .plan-progress-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 1s ease-out;
        }
        
        /* FAQ Item */
        .faq-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            margin-bottom: 1rem;
            overflow: hidden;
            transition: all 0.3s;
        }
        
        .faq-item.active {
            background: rgba(220, 38, 38, 0.1);
        }
        
        .faq-question {
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }
        
        .faq-answer {
            padding: 0 1rem;
            max-height: 0;
            overflow: hidden;
            transition: all 0.3s;
        }
        
        .faq-item.active .faq-answer {
            padding: 0 1rem 1rem;
            max-height: 500px;
        }
        
        /* Payment Methods */
        .payment-method {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        
        .payment-method.active {
            background: linear-gradient(45deg, rgba(220, 38, 38, 0.2), rgba(147, 51, 234, 0.2));
            border: 2px solid #dc2626;
        }
        
        /* Mobile Section */
        .mobile-section {
            padding: 2rem 1rem;
        }
        
        /* Gradient Text */
        .gradient-text {
            background: linear-gradient(90deg, #dc2626, #9333ea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        /* Rocket Animation Container */
        .rocket-container {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 9999;
            display: none;
        }
        
        .rocket {
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 3rem;
            color: #dc2626;
        }
        
        /* Success Modal */
        .success-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.95);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        
        /* Stats Counter */
        .stats-counter {
            font-size: 2.5rem;
            font-weight: bold;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        /* Limited Offer Badge */
        .limited-badge {
            background: linear-gradient(45deg, #dc2626, #9333ea);
            color: white;
            padding: 0.25rem 1rem;
            border-radius: 50px;
            font-weight: bold;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            animation: gradient-blink 2s infinite;
        }
    </style>
</head>
