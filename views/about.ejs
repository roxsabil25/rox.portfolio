    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #000000;
            color: #ffffff;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Mobile Optimizations */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            /* Improve touch targets */
            button, a, .touch-target {
                min-height: 44px;
                min-width: 44px;
            }
            
            /* Better scrolling */
            .scroll-smooth {
                scroll-behavior: smooth;
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #dc2626, #9333ea);
            border-radius: 3px;
        }
        
        /* Mobile Animations */
        @keyframes slide-up-mobile {
            0% { transform: translateY(30px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        
        @keyframes fade-in {
            0% { opacity: 0; }
            100% { opacity: 1; }
        }
        
        @keyframes pulse-mobile {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .animate-slide-up-mobile {
            animation: slide-up-mobile 0.6s ease-out;
        }
        
        .animate-fade-in {
            animation: fade-in 0.8s ease-out;
        }
        
        .animate-pulse-mobile {
            animation: pulse-mobile 2s infinite;
        }
        
        /* Touch Feedback */
        .touch-feedback:active {
            transform: scale(0.95);
            transition: transform 0.1s;
        }
        
        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.5rem 0;
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.3s;
        }
        
        .mobile-nav-item.active {
            background: rgba(220, 38, 38, 0.2);
            color: #dc2626;
        }
        
        .mobile-nav-item:active {
            background: rgba(220, 38, 38, 0.3);
            transform: scale(0.9);
        }
        
        /* Mobile Header */
        .mobile-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.75rem 1rem;
        }
        
        /* Mobile Menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            overflow-y: auto;
        }
        
        .mobile-menu.open {
            transform: translateX(0);
        }
        
        /* Mobile Cards */
        .mobile-card {
            background: linear-gradient(145deg, rgba(30, 30, 30, 0.8), rgba(0, 0, 0, 0.8));
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.3s;
        }
        
        .mobile-card:active {
            transform: scale(0.98);
            border-color: rgba(220, 38, 38, 0.3);
        }
        
        /* Progress Bar for Mobile */
        .mobile-progress {
            height: 6px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            overflow: hidden;
        }
        
        .mobile-progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 1s ease-out;
        }
        
        /* Mobile Timeline */
        .mobile-timeline {
            position: relative;
            padding-left: 2rem;
        }
        
        .mobile-timeline::before {
            content: '';
            position: absolute;
            left: 0.75rem;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #dc2626, #9333ea);
        }
        
        .mobile-timeline-item {
            position: relative;
            margin-bottom: 2rem;
        }
        
        .mobile-timeline-item::before {
            content: '';
            position: absolute;
            left: -2.2rem;
            top: 0.5rem;
            width: 1rem;
            height: 1rem;
            background: #dc2626;
            border-radius: 50%;
            border: 3px solid #000;
        }
        
        /* Mobile Stats */
        .mobile-stat {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        /* Mobile Skill Badge */
        .mobile-skill-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin: 0.25rem;
        }
        
        /* Mobile Section */
        .mobile-section {
            padding: 2rem 1rem;
        }
        
        /* Mobile Gradient Text */
        .mobile-gradient-text {
            background: linear-gradient(90deg, #dc2626, #9333ea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        /* Mobile Button */
        .mobile-button {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            background: linear-gradient(90deg, #dc2626, #9333ea);
            border-radius: 15px;
            font-weight: 600;
            border: none;
            width: 100%;
            transition: all 0.3s;
        }
        
        .mobile-button:active {
            transform: scale(0.95);
            opacity: 0.9;
        }
        
        /* Mobile Avatar */
        .mobile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
           /* border: 3px solid;
           border-image: linear-gradient(45deg, #dc2626, #9333ea) 1; */
            overflow: hidden;
            margin: 0 auto;
        }
        
        /* Mobile Tabs */
        .mobile-tabs {
            display: flex;
            overflow-x: auto;
            padding: 1rem 0;
            gap: 0.5rem;
            -webkit-overflow-scrolling: touch;
        }
        
        .mobile-tabs::-webkit-scrollbar {
            display: none;
        }
        
        .mobile-tab {
            white-space: nowrap;
            padding: 0.75rem 1.5rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s;
        }
        
        .mobile-tab.active {
            background: linear-gradient(90deg, #dc2626, #9333ea);
            border-color: transparent;
        }
        
        .mobile-tab:active {
            transform: scale(0.95);
        }
        
        /* Mobile Backdrop */
        .mobile-backdrop {
            background: linear-gradient(145deg, rgba(20, 20, 20, 0.95), rgba(0, 0, 0, 0.95));
            backdrop-filter: blur(10px);
        }
    </style>
</head>
