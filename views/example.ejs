<!-- 3D ANIMATION STYLES -->
<style>
  /* 3D Card Effects */
  .perspective-1000 {
    perspective: 1000px;
  }
  
  .preserve-3d {
    transform-style: preserve-3d;
  }
  
  .backface-hidden {
    backface-visibility: hidden;
  }
  
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  
  /* Tech Orbs Animation */
  .tech-orb {
    transition: all 0.3s ease;
  }
  
  .tech-orb:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }
  
  /* Floating Animation */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  
  /* Glow Effects */
  .glow-effect {
    box-shadow: 0 0 20px rgba(220, 38, 38, 0.3);
  }
  
  /* Timeline Card Hover */
  .timeline-card:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  
  /* Skill Planet Effects */
  .skill-planet::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, #ff0000, #ff7300, #fffb00, #48ff00, #00ffd5, #002bff, #7a00ff, #ff00c8, #ff0000);
    border-radius: 20px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
  }
  
  .skill-planet:hover::before {
    opacity: 1;
  }
</style>

<!-- 3D INTERACTION SCRIPT -->
<script>
  // Advanced 3D Card Interaction
  document.addEventListener('DOMContentLoaded', function() {
    const card3d = document.getElementById('advanced3dCard');
    const inner3d = document.getElementById('card3dInner');
    
    if (card3d && inner3d) {
      card3d.addEventListener('mousemove', (e) => {
        const rect = card3d.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateY = (x - centerX) / 25;
        const rotateX = (centerY - y) / 25;
        
        inner3d.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      
      card3d.addEventListener('mouseleave', () => {
        inner3d.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
      });
    }
    
    // Animate skill planets on scroll
    const skillPlanets = document.querySelectorAll('.skill-planet');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, index * 100);
        }
      });
    }, { threshold: 0.1 });
    
    skillPlanets.forEach(planet => {
      planet.style.opacity = '0';
      planet.style.transform = 'translateY(20px)';
      planet.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      observer.observe(planet);
    });
    
    // GSAP Animations for Timeline
    if (typeof gsap !== 'undefined') {
      gsap.from('.timeline-card', {
        scrollTrigger: {
          trigger: '.timeline-card',
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        },
        y: 50,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power3.out'
      });
      
      // Floating elements animation
      gsap.to('.tech-orb', {
        y: -5,
        duration: 2,
        repeat: -1,
        yoyo: true,
        ease: 'power1.inOut',
        stagger: 0.2
      });
    }
  });
</script>

