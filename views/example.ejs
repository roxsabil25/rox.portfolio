	const message = document.getElementById('message');

	let reviews = JSON.parse(localStorage.getItem('reviews:v1') || '[]');
	let index = 0;

	function render(){
		track.innerHTML = '';
		if (reviews.length === 0) {
			track.innerHTML = `<div class="min-w-[260px] p-4 bg-white/5 rounded-lg border border-white/10">No reviews yet — be the first!</div>`;
			return;
		}
		reviews.forEach(r => {
			const el = document.createElement('div');
			el.className = 'min-w-[260px] bg-white/5 p-4 rounded-lg border border-white/10';
			el.innerHTML = `<div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center">${(r.name||'U').charAt(0).toUpperCase()}</div><div><strong>${escapeHtml(r.name)}</strong><div class="text-sm text-gray-400">${'★'.repeat(r.rating)}</div></div></div><p class="mt-3 text-gray-300">${escapeHtml(r.message)}</p>`;
			track.appendChild(el);
		});
		// position
		updatePosition();
	}

	function updatePosition(){
		const w = track.children[0] ? track.children[0].getBoundingClientRect().width + 16 : 280;
		track.style.transform = `translateX(${-index * w}px)`;
	}

	function nextSlide(){ if (reviews.length===0) return; index = (index + 1) % reviews.length; updatePosition(); }
	function prevSlide(){ if (reviews.length===0) return; index = (index -1 + reviews.length) % reviews.length; updatePosition(); }

	next.addEventListener('click', nextSlide);
	prev.addEventListener('click', prevSlide);

	// Auto-advance
	let auto = setInterval(nextSlide, 4500);
	track.addEventListener('mouseenter', ()=> clearInterval(auto));
	track.addEventListener('mouseleave', ()=> auto = setInterval(nextSlide,4500));

	form.addEventListener('submit', (e)=>{
		e.preventDefault();
		const r = { name: nameInput.value.trim() || 'Anonymous', rating: Number(rating.value)||5, message: message.value.trim() };
		reviews.unshift(r); // newest first
		if (reviews.length>10) reviews.pop();
		localStorage.setItem('reviews:v1', JSON.stringify(reviews));
		render();
		form.reset();
		nameInput.focus();
	});

	function escapeHtml(str){ return String(str).replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s])); }

	render();
	window.addEventListener('resize', updatePosition);
})();





</script>

</body>
</html>