    <!-- Project Detail Modal -->
    

    <!-- JavaScript -->
    <script>
        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const closeMenu = document.getElementById('closeMenu');
        const mobileMenu = document.getElementById('mobileMenu');
        
        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.add('open');
            document.body.style.overflow = 'hidden';
            createExplosion(menuToggle, 5);
        });
        
        closeMenu.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = 'auto';
            createExplosion(closeMenu, 3);
        });
        
        // Close menu when clicking outside
        mobileMenu.addEventListener('click', (e) => {
            if (e.target === mobileMenu) {
                mobileMenu.classList.remove('open');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Explosion Effect Function
        function createExplosion(element, count) {
            const rect = element.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            for (let i = 0; i < count; i++) {
                const explosion = document.createElement('div');
                explosion.className = 'explosion';
                explosion.style.background = getRandomColor();
                explosion.style.left = centerX + 'px';
                explosion.style.top = centerY + 'px';
                
                // Random properties
                const tx = (Math.random() - 0.5) * 100;
                const ty = (Math.random() - 0.5) * 100;
                const rot = Math.random() * 360;
                
                explosion.style.setProperty('--tx', tx + 'px');
                explosion.style.setProperty('--ty', ty + 'px');
                explosion.style.setProperty('--rot', rot + 'deg');
                
                document.body.appendChild(explosion);
                
                // Trigger animation
                setTimeout(() => {
                    explosion.classList.add('animate');
                }, 10);
                
                // Remove after animation
                setTimeout(() => {
                    explosion.remove();
                }, 600);
            }
        }
        
        function getRandomColor() {
            const colors = [
                'linear-gradient(45deg, #dc2626, #9333ea)',
                'linear-gradient(45deg, #3b82f6, #8b5cf6)',
                'linear-gradient(45deg, #10b981, #3b82f6)',
                'linear-gradient(45deg, #f59e0b, #dc2626)',
                'linear-gradient(45deg, #8b5cf6, #ec4899)'
            ];
            return colors[Math.floor(Math.random() * colors.length)];
        }
        
        // // Project Filtering
        // const filterButtons = document.querySelectorAll('.filter-btn');
        // const projectCards = document.querySelectorAll('.project-card');
        
        // filterButtons.forEach(button => {
        //     button.addEventListener('click', function() {
        //         // Update active button
        //         filterButtons.forEach(btn => btn.classList.remove('active'));
        //         this.classList.add('active');
                
        //         // Get filter value
        //         const filterValue = this.getAttribute('data-filter');
                
        //         // Filter projects
        //         projectCards.forEach(card => {
        //             const categories = card.getAttribute('data-category');
                    
        //             if (filterValue === 'all' || categories.includes(filterValue)) {
        //                 card.style.display = 'block';
        //                 card.classList.add('animate-explode');
        //             } else {
        //                 card.style.display = 'none';
        //             }
        //         });
                
        //         // Create explosion effect
        //         createExplosion(this, 4);
        //     });
        // });
        
        // Ripple Effect
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('aggressive-tap') || 
                e.target.closest('.aggressive-tap')) {
                const target = e.target.classList.contains('aggressive-tap') ? 
                    e.target : e.target.closest('.aggressive-tap');
                
                // Create ripple
                const ripple = document.createElement('span');
                const rect = target.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                const x = e.clientX - rect.left - size / 2;
                const y = e.clientY - rect.top - size / 2;
                
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = x + 'px';
                ripple.style.top = y + 'px';
                ripple.classList.add('ripple');
                
                target.style.position = 'relative';
                target.style.overflow = 'hidden';
                target.appendChild(ripple);
                
                // Remove ripple after animation
                setTimeout(() => {
                    ripple.remove();
                }, 600);
                
                // Add aggressive shake
                target.classList.add('animate-shake-aggressive');
                setTimeout(() => {
                    target.classList.remove('animate-shake-aggressive');
                }, 500);
            }
        });
        
        // Project Modal
        const projectModal = document.getElementById('projectModal');
        const closeModalBtn = document.getElementById('closeModal');
        const projectLinks = document.querySelectorAll('.project-card a');
        
        // Sample project data (in a real app, this would come from a database)
        const projectsData = {
            'project1': {
                title: 'Aggressive Portfolio V2',
                category: 'Web Development',
                description: 'A mobile-first portfolio with explosive animations, dark theme design, and aggressive UI elements. Fully responsive across all devices with touch-optimized interactions.',
                skills: ['HTML5', 'CSS3', 'JavaScript', 'Tailwind', 'Responsive Design', 'Animations'],
                demoLink: '#',
                githubLink: '#',
                color: 'from-red-600/20 to-purple-600/20',
                icon: 'fa-laptop-code',
                iconColor: 'text-red-500'
            },
            'project2': {
                title: 'Secure Banking App',
                category: 'Web & Mobile',
                description: 'Military-grade secure banking application with end-to-end encryption, biometric authentication, and real-time fraud detection. Built with security-first approach.',
                skills: ['React', 'Node.js', 'MongoDB', 'JWT', 'Encryption', 'PWA'],
                demoLink: '#',
                githubLink: '#',
                color: 'from-blue-600/20 to-cyan-600/20',
                icon: 'fa-shield-alt',
                iconColor: 'text-blue-500'
            }
        };
        
        // Open modal when project card is clicked
        document.querySelectorAll('.project-card').forEach((card, index) => {
            card.addEventListener('click', function(e) {
                if (!e.target.closest('a')) {
                    const projectId = `project${index + 1}`;
                    const project = projectsData[projectId] || {
                        title: this.querySelector('h2').textContent,
                        category: this.getAttribute('data-category'),
                        description: this.querySelector('h3').textContent,
                        skills: Array.from(this.querySelectorAll('.skill-tag')).map(tag => tag.textContent),
                        demoLink: this.querySelector('a[href*="#"]')?.href || '#',
                        githubLink: this.querySelector('a[href*="github"]')?.href || '#',
                        color: 'from-red-600/20 to-purple-600/20',
                        icon: 'fa-laptop-code',
                        iconColor: 'text-red-500'
                    };
                    
                    // Set modal content
                    document.getElementById('modalTitle').textContent = project.title;
                    document.getElementById('modalCategory').textContent = project.category;
                    document.getElementById('modalDescription').textContent = project.description;
                    
                    // Set skills
                    const skillsContainer = document.getElementById('modalSkills');
                    skillsContainer.innerHTML = '';
                    project.skills.forEach(skill => {
                        const skillTag = document.createElement('span');
                        skillTag.className = 'skill-tag';
                        skillTag.textContent = skill;
                        skillsContainer.appendChild(skillTag);
                    });
                    
                    // Set links
                    document.getElementById('modalDemo').href = project.demoLink;
                    document.getElementById('modalGithub').href = project.githubLink;
                    
                    // Set image
                    const modalImage = document.getElementById('modalImage');
                    modalImage.className = `project-image bg-gradient-to-br ${project.color} flex items-center justify-center mb-6`;
                    modalImage.innerHTML = `<i class="fas ${project.icon} text-5xl ${project.iconColor}"></i>`;
                    
                    // Show modal
                    projectModal.classList.remove('hidden');
                    projectModal.classList.add('flex');
                    document.body.style.overflow = 'hidden';
                    
                    // Create explosion
                    createExplosion(this, 8);
                }
            });
        });
        
        // Close modal
        closeModalBtn.addEventListener('click', function() {
            projectModal.classList.add('hidden');
            projectModal.classList.remove('flex');
            document.body.style.overflow = 'auto';
            createExplosion(this, 5);
        });
        
        // Close modal when clicking outside
        projectModal.addEventListener('click', function(e) {
            if (e.target === projectModal) {
                projectModal.classList.add('hidden');
                projectModal.classList.remove('flex');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Theme toggle
        const themeToggle = document.getElementById('themeToggle');
        let aggressiveMode = true;
        
        themeToggle.addEventListener('click', function() {
            aggressiveMode = !aggressiveMode;
            
            if (aggressiveMode) {
                document.body.style.background = '#000000';
                this.innerHTML = '<i class="fas fa-bolt"></i>';
                this.style.background = '';
                this.classList.add('animate-aggressive-pulse');
                
                // Update all aggressive buttons
                document.querySelectorAll('.aggressive-button').forEach(btn => {
                    btn.style.background = 'linear-gradient(90deg, #dc2626, #9333ea)';
                });
            } else {
                document.body.style.background = 'linear-gradient(45deg, #0a0a0a, #1a1a2e)';
                this.innerHTML = '<i class="fas fa-moon"></i>';
                this.style.background = 'linear-gradient(90deg, #3b82f6, #1e40af)';
                this.classList.remove('animate-aggressive-pulse');
                
                // Update all aggressive buttons
                document.querySelectorAll('.aggressive-button').forEach(btn => {
                    btn.style.background = 'linear-gradient(90deg, #3b82f6, #1e40af)';
                });
            }
            
            createExplosion(this, 6);
        });
        
        // Initialize animations
        document.addEventListener('DOMContentLoaded', function() {
            // Animate cards sequentially
            const explodeCards = document.querySelectorAll('.animate-explode');
            explodeCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
            });
            
            // Add floating particles
            createFloatingParticles();
            
            // Auto shake header occasionally
            setInterval(() => {
                const header = document.querySelector('.mobile-header');
                header.classList.add('animate-shake-aggressive');
                setTimeout(() => {
                    header.classList.remove('animate-shake-aggressive');
                }, 500);
            }, 15000);
        });
        
        // Create floating particles
        function createFloatingParticles() {
            const container = document.querySelector('main');
            const particles = 8;
            
            for (let i = 0; i < particles; i++) {
                const particle = document.createElement('div');
                particle.className = 'absolute w-2 h-2 rounded-full hidden md:block';
                particle.style.background = getRandomColor();
                particle.style.opacity = '0.3';
                
                // Random positioning
                const left = Math.random() * 100;
                const top = Math.random() * 100;
                const duration = 3 + Math.random() * 4;
                const delay = Math.random() * 5;
                
                particle.style.left = `${left}%`;
                particle.style.top = `${top}%`;
                particle.style.animation = `float-aggressive ${duration}s ease-in-out infinite`;
                particle.style.animationDelay = `${delay}s`;
                
                container.appendChild(particle);
            }
        }
        
        // Copy WhatsApp number functionality
        document.querySelectorAll('.fa-copy').forEach(icon => {
            icon.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const phoneNumber = '+8801749935208';
                navigator.clipboard.writeText(phoneNumber).then(() => {
                    // Show copied notification
                    const notification = document.createElement('div');
                    notification.className = 'fixed top-24 right-4 bg-gradient-to-r from-green-600 to-green-800 p-3 rounded-xl z-50 animate-explode';
                    notification.innerHTML = `
                        <div class="flex items-center gap-2">
                            <i class="fas fa-check"></i>
                            <span>Copied to clipboard!</span>
                        </div>
                    `;
                    
                    document.body.appendChild(notification);
                    
                    setTimeout(() => {
                        notification.remove();
                    }, 2000);
                    
                    createExplosion(this, 3);
                });
            });
        });
        
        // Handle orientation change
        window.addEventListener('orientationchange', function() {
            // Refresh animations
            setTimeout(() => {
                document.querySelectorAll('.animate-explode').forEach(el => {
                    el.style.animation = 'none';
                    setTimeout(() => {
                        el.style.animation = '';
                    }, 10);
                });
            }, 300);
        });
    </script>
</body>
