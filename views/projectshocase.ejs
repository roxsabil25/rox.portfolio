                    <span class="text-xs mt-1">Contact</span>
                </a>
                <a href="/plan" class="mobile-nav-item">
                    <i class="fas fa-rocket text-lg"></i>
                    <span class="text-xs mt-1">Plan</span>
                </a>
            </div>
        </div>
