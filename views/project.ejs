    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #000000;
            color: #ffffff;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Mobile Optimizations */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            /* Prevent horizontal scroll */
            .container {
                width: 100%;
                padding-left: 1rem;
                padding-right: 1rem;
            }
            
            /* Improve touch targets */
            button, a, .touch-target {
                min-height: 44px;
                min-width: 44px;
            }
        }
        
        /* Custom Scrollbar for Mobile */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #dc2626, #9333ea);
            border-radius: 3px;
        }
        
        /* Mobile-First Animations */
        @keyframes mobile-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
        }
        
        @keyframes slide-up {
            0% { transform: translateY(50px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
            20%, 40%, 60%, 80% { transform: translateX(5px); }
        }
        
        @keyframes float-mobile {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            33% { transform: translateY(-10px) rotate(5deg); }
            66% { transform: translateY(5px) rotate(-5deg); }
        }
        
        .animate-mobile-pulse {
            animation: mobile-pulse 2s infinite;
        }
        
        .animate-slide-up {
            animation: slide-up 0.8s ease-out;
        }
        
        .animate-shake {
            animation: shake 0.5s;
        }
        
        .animate-float-mobile {
            animation: float-mobile 6s ease-in-out infinite;
        }
        
        /* Aggressive Mobile Effects */
        .aggressive-tap:active {
            transform: scale(0.95);
            transition: transform 0.1s;
        }
        
        .aggressive-hover {
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        .aggressive-hover:active {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(220, 38, 38, 0.4);
        }
        
        /* Mobile 3D Card */
        .mobile-3d-card {
            transform-style: preserve-3d;
            transition: transform 0.5s;
        }
        
        .mobile-3d-card:active {
            transform: rotateY(10deg) rotateX(5deg);
        }
        
        /* Swipe Indicators */
        .swipe-indicator {
            width: 40px;
            height: 5px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 3px;
            position: relative;
        }
        
        .swipe-indicator::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 20px;
            height: 5px;
            background: #dc2626;
            border-radius: 3px;
            animation: swipe 2s infinite;
        }
        
        @keyframes swipe {
            0% { transform: translateX(0); }
            50% { transform: translateX(20px); }
            100% { transform: translateX(0); }
        }
        
        /* Mobile Glitch Effect */
        .mobile-glitch {
            position: relative;
        }
        
        .mobile-glitch::before,
        .mobile-glitch::after {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            clip: rect(0, 900px, 0, 0);
        }
        
        .mobile-glitch::before {
            left: 2px;
            text-shadow: -1px 0 #ff00ff;
            animation: glitch-anim-1 2s infinite linear alternate-reverse;
        }
        
        .mobile-glitch::after {
            left: -2px;
            text-shadow: 1px 0 #00ffff;
            animation: glitch-anim-2 3s infinite linear alternate-reverse;
        }
        
        @keyframes glitch-anim-1 {
            0% { clip: rect(20px, 9999px, 25px, 0); }
            5% { clip: rect(15px, 9999px, 30px, 0); }
            10% { clip: rect(40px, 9999px, 45px, 0); }
            15% { clip: rect(60px, 9999px, 65px, 0); }
            20% { clip: rect(80px, 9999px, 85px, 0); }
            100% { clip: rect(0, 9999px, 0, 0); }
        }
        
        @keyframes glitch-anim-2 {
            0% { clip: rect(10px, 9999px, 15px, 0); }
            5% { clip: rect(25px, 9999px, 30px, 0); }
            10% { clip: rect(35px, 9999px, 40px, 0); }
            15% { clip: rect(55px, 9999px, 60px, 0); }
            20% { clip: rect(75px, 9999px, 80px, 0); }
            100% { clip: rect(0, 9999px, 0, 0); }
        }
        
        /* Haptic Feedback Simulation */
        .haptic-feedback {
            animation: haptic 0.1s;
        }
        
        @keyframes haptic {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(2px); }
            75% { transform: translateX(-2px); }
        }
        
        /* Mobile Project Card */
        .project-card {
            position: relative;
            overflow: hidden;
            border-radius: 20px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        .project-card:active {
            transform: scale(0.98);
        }
        
        .project-card-content {
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.7) 50%, transparent 100%);
            padding: 1.5rem;
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            transform: translateY(100%);
            transition: transform 0.4s;
        }
        
        .project-card:hover .project-card-content,
        .project-card:active .project-card-content {
            transform: translateY(0);
        }
        
        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 100;
            padding: 0.5rem 0;
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.3s;
        }
        
        .mobile-nav-item.active {
            background: rgba(220, 38, 38, 0.2);
            color: #dc2626;
        }
        
        .mobile-nav-item:active {
            background: rgba(220, 38, 38, 0.3);
            transform: scale(0.9);
        }
        
        /* Mobile Project Filter */
        .mobile-filter {
    display: flex;
    overflow-x: auto;
    padding: 1rem 0;
    gap: 1.5rem;
    -webkit-overflow-scrolling: touch;
    flex-wrap: wrap;
        }
        
        .mobile-filter::-webkit-scrollbar {
            display: none;
        }
        
        .mobile-filter-item {
            white-space: nowrap;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s;
        }
        
        .mobile-filter-item.active {
            background: #dc2626;
            border-color: #dc2626;
            box-shadow: 0 5px 15px rgba(220, 38, 38, 0.3);
        }
        
        .mobile-filter-item:active {
            transform: scale(0.95);
        }
    </style>
</head>
